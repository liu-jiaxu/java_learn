<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

        <!--servlet类标签配置-->
        <servlet>
            <!--给定一个声明名字-->
            <servlet-name>ts2</servlet-name>
            <!--servlet全类名-->
            <servlet-class>com.example.servlet.TS2_Test</servlet-class>
            <!--配置Servlet的创建时机
                    1.首次访问时创建：<load-on-startup>值为负数
                    2.服务器启动时创建：<load-on-startup>值为0或正数
                -->
            <load-on-startup>3</load-on-startup>

        </servlet>
        <!--映射一个servlet访问的URl路径-->
        <servlet-mapping>
            <!--指定要映射的servlet名称-->
            <servlet-name>ts2</servlet-name>
            <!--指定访问servlet的url路径-->
            <url-pattern>/ts2</url-pattern>
        </servlet-mapping>
    <!--
        servlet执行原理：
            1.当服务器接收到客户端浏览器的请求后，会解析请求URL路径，获取访问的Servlet的资源路径
                例：本web.xml路径文URL+/ts2即为http://localhost:8080/ts2(URL为Tomcat配置路径)
            2.查找web.xml文件对应的<url-pattern>标签内容，并找到对应的<servlet-name>标签内容
            3.根据<servlet-name>标签内容找到对应的<servlet-class>全类名
            4.tomcat将全类名对应字节码文件加载进内存，并创建对象调用service方法
                Class.forName() -> class.newInstance() -> 调用service方法
    -->

    <!--可以配置多个servlet标签用于不同的url和全类名-->
    <servlet>
        <servlet-name>aa</servlet-name>
        <servlet-class>com.example.servlet.TS2_Test</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>aa</servlet-name>
        <url-pattern>/aa</url-pattern>
    </servlet-mapping>

</web-app>